{
  "name": "better-react-web-ui",
  "version": "2.4.0",
  "private": true,
  "type": "module",
  "description": "Opinionated React and Tailwind frontend design Agent Skills package for AI coding agents.",
  "license": "LicenseRef-better-react-web-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aladicf/better-react-web-ui.git"
  },
  "homepage": "https://github.com/aladicf/better-react-web-ui",
  "bugs": {
    "url": "https://github.com/aladicf/better-react-web-ui/issues"
  },
  "keywords": [
    "agent-skills",
    "agents",
    "design",
    "frontend",
    "skills",
    "ui"
  ],
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "lint": "oxlint --deny-warnings scripts",
    "generate:wrappers": "node ./scripts/generate-wrappers.mjs",
    "check:wrapper-drift": "node ./scripts/check-generated-wrapper-diff.mjs",
    "validate": "node ./scripts/validate-skill-library.mjs",
    "validate:wrappers": "node ./scripts/validate-skill-library.mjs --wrappers-only",
    "smoke:list": "npx skills add . --list",
    "smoke:install": "node ./scripts/smoke-install-skill.mjs",
    "check:skill-descriptions": "node ./scripts/check-skill-descriptions.mjs",
    "generate:compatibility-matrix": "node ./scripts/generate-compatibility-matrix.mjs",
    "check:compatibility-matrix": "node ./scripts/check-compatibility-matrix-drift.mjs",
    "check:reference-index": "node ./scripts/check-reference-index.mjs",
    "check:skill-routing-fixtures": "node ./scripts/check-skill-routing-fixtures.mjs",
    "verify": "npm run lint && npm run generate:wrappers && npm run validate && npm run check:compatibility-matrix && npm run check:reference-index && npm run check:skill-routing-fixtures && npm run smoke:list && npm run smoke:install",
    "release:check": "npm run verify"
  },
  "devDependencies": {
    "oxlint": "^1.20.0",
    "yaml": "^2.8.1"
  }
}
